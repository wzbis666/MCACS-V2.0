# ============================================================
# Minecraft AntiCheat System — 环境变量配置
# 复制此文件为 .env 并修改: cp .env.example .env
# ============================================================

# 时区设置
TZ=Asia/Shanghai

# WebSocket 连接认证密钥（强烈建议设置）
# 生成方法: openssl rand -hex 32
# 设置后，Spigot 插件和浏览器前端连接时需携带此 token
# 不设置则允许所有连接（仅推荐开发环境使用）
ACS_AUTH_SECRET=

# 管理面板监听地址
# 本机开发可用 127.0.0.1；服务器/容器部署需要 0.0.0.0 才能从外部访问
ACS_HTTP_HOST=127.0.0.1

# 运行环境: production | development
NODE_ENV=production
