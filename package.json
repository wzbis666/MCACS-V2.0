{
  "name": "minecraft-anticheat",
  "version": "0.1.0",
  "description": "Minecraft Spigot anti-cheat monitoring system with 3D visualization",
  "main": "./src/plugin/index.ts",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/plugin/index.ts",
    "start": "tsx src/plugin/index.ts",
    "build": "tsc",
    "build:spigot": "cd spigot-plugin && mvn clean package -q",
    "build:frontend": "cd town-frontend && npx tsc --noEmit",
    "build:all": "tsc && cd spigot-plugin && mvn clean package -q && cd ../town-frontend && npx tsc --noEmit",
    "watch:build": "node watch-build.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
